VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_ONTIVER_API_BASE_URL=https://api.yourdomain.com
VITE_ONTIVER_AUTH_BASE_URL=https://api.yourdomain.com
VITE_ONTIVER_BANKING_BASE_URL=https://api.yourdomain.com
VITE_SECURITY_STEP_UP_ENABLED=true
VITE_SECURITY_NONCE_ENABLED=true
VITE_SECURITY_POLICY_UI_ENABLED=true

# Temporary local development switches:
# - Keep mock auth on so you can sign in without the live auth backend.
# - Unlock every dashboard route so you can edit user, verifier, enterprise, manager, and admin pages from one session.
# Set both values back to false later when you want the normal auth + RBAC flow again.
# These values are development-only and should not be treated as production defaults.
VITE_MOCK_AUTH_ENABLED=true
VITE_DEV_UNLOCK_ALL_ROUTES=false
